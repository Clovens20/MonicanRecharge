# Copiez vers `.env` à la racine du dépôt et renseignez les valeurs.

# App
# Local : http://localhost:3100 (voir `npm run dev`). Prod / OG : https://recharge.monican.shop
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Supabase (projet Monican — ref: ujyjdqmqormbjyfuuwgq)
NEXT_PUBLIC_SUPABASE_URL=https://ujyjdqmqormbjyfuuwgq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- CLI Supabase (db push / functions deploy) — erreurs « link » / « Access token » ---
# 1) Connexion (une fois) :   npm run supabase:login
# 2) Lier ce dépôt au projet cloud (même ref que dans l’URL .supabase.co) :
#    npm run supabase -- link --project-ref ujyjdqmqormbjyfuuwgq
#    (mot de passe DB demandé la 1re fois pour db push / migrations)
# 3) CI / sans navigateur : créer un token sur https://supabase.com/dashboard/account/tokens
#    puis dans PowerShell AVANT les commandes deploy :
#    $env:SUPABASE_ACCESS_TOKEN="sbp_..."
#    (ne jamais committer ce token dans .env versionné)
# E-mails de confirmation (signup) : dans Supabase → Authentication → URL configuration,
# ajoutez les Redirect URLs (ex. http://localhost:3102/auth/konplete) et configurez SMTP / fournisseur mail si les messages n’arrivent pas.

# Reloadly — OAuth client credentials (dashboard Reloadly → API)
# https://developers.reloadly.com — POST https://auth.reloadly.com/oauth/token
#   body: client_id, client_secret, grant_type=client_credentials, audience
#   audience sandbox: https://topups-sandbox.reloadly.com  |  live: https://topups.reloadly.com
RELOADLY_CLIENT_ID=
# « Client Secret » du dashboard (pas le même nom que « API Key » gift cards — ici c’est le secret Topups)
RELOADLY_CLIENT_SECRET=
# Alias acceptés si tu as déjà nommé les vars autrement :
# RELOADLY_API_CLIENT_ID=  RELOADLY_API_SECRET=  ou RELOADLY_API_KEY= (secret uniquement)
RELOADLY_SANDBOX_MODE=true
# Numéro expéditeur exigé par l’API topups (format pays + numéro sans +)
RELOADLY_SENDER_COUNTRY=US
RELOADLY_SENDER_NUMBER=17178801479

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# MongoDB (optionnel — persistance des transactions `/api/recharge/*`)
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=monican_recharge

# Reçu e-mail (Resend — équivalent route API `POST /api/receipt/email`)
RESEND_API_KEY=
EMAIL_FROM=noreply@monican.shop
EMAIL_FROM_NAME=Monican Recharge

# Nom caissier par défaut (si non saisi dans Tableau de bord → Caisse)
NEXT_PUBLIC_CAISSE_DEFAULT_NAME=

# Admin (virgule) — aksè /admin, /api/admin/*
ADMIN_EMAILS=
# Mèm lis (virgule) pou kliyan: redireksyon /admin apre login, bouton Admin
# Mete menm imèl ke ADMIN_EMAILS pou /admin ouvri pi vit (sans atenn tout a /api/auth/is-admin).
NEXT_PUBLIC_ADMIN_EMAILS=

# Kèsye boutik (NIP 4 chif sur /recharge) — pepper pou hash NIP, sekè cookie sesyon
KESYE_PEPPER=
KESYE_SESSION_SECRET=
# Notifikasyon nouvo aplikasyon ajan (opsyonèl)
ADMIN_NOTIFY_EMAIL=

# Cron rapèl komisyon (Header: Authorization: Bearer …)
CRON_SECRET=

# Reloadly — balans manyèl + alèt (cron verify-reloadly-balance)
RELOADLY_BALANCE_USD=0
RELOADLY_MIN_ALERT_USD=50

# Moncash manyèl
NEXT_PUBLIC_MONCASH_QR_IMAGE_URL=
MONCASH_MERCHANT_PHONE=
NEXT_PUBLIC_MONCASH_MERCHANT_PHONE=

# Twilio WhatsApp (opsyonèl — nimewo format E.164)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_NOTIFY_RECHARGE_TO=
TWILIO_ADMIN_MONCASH_ALERT_TO=
TWILIO_ADMIN_RELOADLY_ALERT_TO=

# Sekirite recharge (opsyonèl)
RECHARGE_MAX_USD=100
RECHARGE_MAX_DAY_USER_USD=200
RECHARGE_MAX_DAY_CAISSE_USD=500
# AUTO_SUSPEND_FRAUD=true — ban 24h si telefòn repete + BLOCK_PHONE_SPAM=true bloke
AUTO_SUSPEND_FRAUD=
BLOCK_PHONE_SPAM=
